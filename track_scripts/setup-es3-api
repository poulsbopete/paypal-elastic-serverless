  curl -sf -X POST "http://localhost:${DEMO_PORT}/api/setup/launch" \
    -H 'Content-Type: application/json' \
    -d "{\"scenario_id\":\"fanatics\",\"kibana_url\":\"${DEMO_KIBANA_URL}\",\"api_key\":\"${DEMO_API_KEY}\",\"otlp_url\":\"${DEMO_OTLP_URL}\"}" \
    >/dev/null 2>&1 || echo "WARN: Launch request failed — learners can launch manually via the Demo App tab."

  echo "Waiting for deployment to register..."
  for i in $(seq 1 60); do
    RUNNING="$(curl -sf "http://localhost:${DEMO_PORT}/api/deployments" 2>/dev/null \
      | python3 -c "import sys,json; deps=json.load(sys.stdin); print(sum(1 for d in deps if d.get('running')))" 2>/dev/null || echo 0)"
    if [[ "$RUNNING" -ge 1 ]]; then
      echo "Deployment active after $((i*2))s ✓"
      break
    fi
    if [[ $i -eq 60 ]]; then
      echo "WARN: Deployment did not register after 120s — learners can launch manually."
    fi
    sleep 2
  done
elif [[ "$DEMO_HEALTHY" != "true" ]]; then
  echo "WARN: Skipping scenario launch — demo app never became healthy."
else
  echo "WARN: Missing Kibana URL or API key — skipping auto-launch."
fi

# ── Index Aliases for ES|QL convenience ──────────────────────────────────────
# Create short aliases so learners can use `logs.otel` as a friendly name.
# These are created against the APM data streams that OTLP ingest populates.
# We wait up to 60s for at least one data stream to exist before aliasing.
if [[ -n "$ES_URL" && -n "$ELASTICSEARCH_API_KEY" ]]; then
  echo "Waiting for OTLP data streams to appear..."
  for i in $(seq 1 30); do
    DS_COUNT=$(curl -sf "${ES_URL}/_data_stream/logs-apm.otel-*" \
      -H "Authorization: ApiKey ${ELASTICSEARCH_API_KEY}" 2>/dev/null \
      | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('data_streams',[])))" 2>/dev/null || echo 0)
    if [[ "$DS_COUNT" -ge 1 ]]; then
      echo "Data streams found after $((i*2))s ($DS_COUNT streams) ✓"
      break
    fi
    if [[ $i -eq 30 ]]; then
      echo "WARN: No OTLP data streams after 60s — aliases may not be created."
    fi
    sleep 2
  done

  # Create data stream aliases so legacy query `FROM logs.otel` works
  for DS_ALIAS in "logs.otel:logs-apm.otel-*" "traces.otel:traces-apm.otel-*" "metrics.otel:metrics-apm.otel-*"; do
    ALIAS="${DS_ALIAS%%:*}"
    PATTERN="${DS_ALIAS##*:}"
    # Get concrete stream names matching the pattern
    STREAMS=$(curl -sf "${ES_URL}/_data_stream/${PATTERN}" \
      -H "Authorization: ApiKey ${ELASTICSEARCH_API_KEY}" 2>/dev/null \
      | python3 -c "import sys,json; d=json.load(sys.stdin); print('\n'.join(s['name'] for s in d.get('data_streams',[])))" 2>/dev/null || true)
    if [[ -z "$STREAMS" ]]; then
      echo "  WARN: No data streams matched $PATTERN — skipping alias $ALIAS"
      continue
    fi
    # Build actions array
    ACTIONS="[]"
    while IFS= read -r STREAM; do
      [[ -z "$STREAM" ]] && continue
      ACTIONS=$(echo "$ACTIONS" | python3 -c "
import sys, json
acts = json.load(sys.stdin)
acts.append({'add': {'index': '${STREAM}', 'alias': '${ALIAS}'}})
print(json.dumps(acts))
")
    done <<< "$STREAMS"
    HTTP=$(curl -s -o /tmp/alias_resp.json -w "%{http_code}" -X POST \
      "${ES_URL}/_aliases" \
      -H "Authorization: ApiKey ${ELASTICSEARCH_API_KEY}" \
      -H "Content-Type: application/json" \
      -d "{\"actions\":${ACTIONS}}")
    if [[ "$HTTP" == "200" ]]; then
      echo "  Alias created: $ALIAS → $PATTERN ✓"
    else
      echo "  WARN: Alias $ALIAS returned HTTP $HTTP"
      cat /tmp/alias_resp.json 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('error',{}).get('reason',''))" 2>/dev/null || true
    fi
  done
  echo "Index aliases done."
fi

# ── ML Anomaly Detection Jobs ─────────────────────────────────────────────────
# Create 3 ML jobs that detect anomalies in PayPal merchant transactions.
# Jobs run against logs-apm.otel-* once data starts flowing.
if [[ -n "$ES_URL" && -n "$ELASTICSEARCH_API_KEY" ]]; then
  echo "Creating PayPal ML anomaly detection jobs..."

  # Helper: create a job + datafeed, open + start
  create_ml_job() {
    local JOB_ID="$1"
    local JOB_JSON="$2"
    local FEED_JSON="$3"

    # Create job
    HTTP=$(curl -s -o /tmp/ml_resp.json -w "%{http_code}" -X PUT \
      "${ES_URL}/_ml/anomaly_detectors/${JOB_ID}?pretty" \
      -H "Authorization: ApiKey ${ELASTICSEARCH_API_KEY}" \
      -H "Content-Type: application/json" \
      -d "$JOB_JSON")
    if [[ "$HTTP" == "200" || "$HTTP" == "201" ]]; then
      echo "  ML job created: $JOB_ID ✓"
    else
      echo "  WARN: ML job $JOB_ID returned HTTP $HTTP"
      cat /tmp/ml_resp.json 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('error',{}).get('reason',''))" 2>/dev/null || true
      return
    fi

    # Create datafeed
    curl -s -o /dev/null -X PUT \
      "${ES_URL}/_ml/datafeeds/datafeed-${JOB_ID}" \
      -H "Authorization: ApiKey ${ELASTICSEARCH_API_KEY}" \
      -H "Content-Type: application/json" \
      -d "$FEED_JSON" || true

    # Open job
    curl -s -o /dev/null -X POST \
      "${ES_URL}/_ml/anomaly_detectors/${JOB_ID}/_open" \
      -H "Authorization: ApiKey ${ELASTICSEARCH_API_KEY}" || true

    # Start datafeed (real-time from now)
    curl -s -o /dev/null -X POST \
      "${ES_URL}/_ml/datafeeds/datafeed-${JOB_ID}/_start" \
      -H "Authorization: ApiKey ${ELASTICSEARCH_API_KEY}" \
      -H "Content-Type: application/json" \
      -d '{"start":"now-1h"}' || true
  }

  # Job 1: Error spike per service — catches P1 incidents instantly
  create_ml_job "paypal-service-error-spike" \
  '{
    "description": "PayPal — detect error rate spikes per service (payment failures, 5xx storms)",
    "analysis_config": {
      "bucket_span": "5m",
      "detectors": [{
        "function": "high_count",
        "detector_description": "Unusually high error log count",
        "partition_field_name": "service.name"
      }],
      "influencers": ["service.name"]
    },
    "data_description": { "time_field": "@timestamp" },
    "analysis_limits": { "model_memory_limit": "20mb" },
    "custom_settings": { "created_by": "paypal-elastic-serverless" }
  }' \
  "{
    \"job_id\": \"paypal-service-error-spike\",
    \"indices\": [\"logs.otel\"],
    \"query\": {\"term\": {\"severity_text\": {\"value\": \"ERROR\"}}},
    \"scroll_size\": 1000,
    \"frequency\": \"1m\",
    \"query_delay\": \"60s\"
  }"

  # Job 2: Transaction volume anomaly — catches traffic drops (outages) and surges (attacks)
  create_ml_job "paypal-transaction-volume-anomaly" \
  '{
    "description": "PayPal — detect unusual transaction volumes per service (drops or surges)",
    "analysis_config": {
      "bucket_span": "5m",
      "detectors": [{
        "function": "count",
        "detector_description": "Unusual transaction volume",
        "partition_field_name": "service.name"
      }],
      "influencers": ["service.name"]
    },
    "data_description": { "time_field": "@timestamp" },
    "analysis_limits": { "model_memory_limit": "20mb" },
    "custom_settings": { "created_by": "paypal-elastic-serverless" }
  }' \
  "{
    \"job_id\": \"paypal-transaction-volume-anomaly\",
    \"indices\": [\"logs.otel\"],
    \"query\": {\"match_all\": {}},
    \"scroll_size\": 1000,
    \"frequency\": \"1m\",
    \"query_delay\": \"60s\"
  }"

  # Job 3: Checkout service degradation — watches checkout-service + payments-orchestrator
  create_ml_job "paypal-checkout-degradation" \
  '{
    "description": "PayPal — detect checkout and payment orchestration degradation",
    "analysis_config": {
      "bucket_span": "5m",
      "detectors": [{
        "function": "high_count",
        "detector_description": "Error surge in checkout pipeline",
        "partition_field_name": "service.name"
      }],
      "influencers": ["service.name"]
    },
    "data_description": { "time_field": "@timestamp" },
    "analysis_limits": { "model_memory_limit": "20mb" },
    "custom_settings": { "created_by": "paypal-elastic-serverless" }
  }' \
  "{
    \"job_id\": \"paypal-checkout-degradation\",
    \"indices\": [\"logs.otel\"],
    \"query\": {
      \"terms\": {
        \"service.name\": [\"checkout-service\", \"payments-orchestrator\", \"fraud-decisioning\", \"merchant-api\"]
      }
    },
    \"scroll_size\": 1000,
    \"frequency\": \"1m\",
    \"query_delay\": \"60s\"
  }"

  echo "ML anomaly detection jobs created and started ✓"
else
  echo "WARN: Skipping ML jobs — ES_URL or API key not set."
fi

