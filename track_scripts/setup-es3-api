def _rand_id(n=16):
    return hashlib.sha256(str(random.random()).encode()).hexdigest()[:n*2]

def _otlp_id(n_bytes):
    """Return n_bytes of random data base64-encoded — required by OTLP JSON spec.
    traceId = _otlp_id(16), spanId = _otlp_id(8)"""
    return base64.b64encode(os.urandom(n_bytes)).decode()

def _ts_ns():
    return int(time.time() * 1e9)

def _attrs(svc):
