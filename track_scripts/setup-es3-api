# Patch telemetry.py: surface ALL OTLP HTTP errors (4xx/5xx) which were previously silent.
# Strategy: find the _send method's try/except block and:
#   1. Add raise_for_status() after the response so non-2xx throws HTTPStatusError
#   2. Catch HTTPStatusError explicitly and log status + body snippet
#   3. Also log network errors
python3 - <<'TELEMETRY_PATCH_EOF'
import sys, re

path = "/opt/elastic-launch-demo/app/telemetry.py"
try:
    with open(path) as f:
        content = f.read()

    applied = []

    # --- Patch 1: add raise_for_status() right after response = client.post(...)
    # Matches:   response = self._client.post(url, ...)  (any args)
    # Inserts:   response.raise_for_status()   on the next line with same indent
    pat1 = r'([ \t]+)(response\s*=\s*(?:self\._client|client)\.post\([^)]+\))\n(?!\s*response\.raise_for_status)'
    def inject_raise(m):
        indent = m.group(1)
        return f"{indent}{m.group(2)}\n{indent}response.raise_for_status()\n"
    new_content, n = re.subn(pat1, inject_raise, content)
    if n:
        content = new_content
        applied.append(f"raise_for_status() injected ({n} site(s))")

    # --- Patch 2: broaden the except clause to also catch HTTPStatusError
    pat2 = r'(\s+)(except\s+httpx\.RequestError\s+as\s+exc\s*:)'
    def broaden_except(m):
        indent = m.group(1)
        return (
            f"{indent}except httpx.HTTPStatusError as exc:\n"
            f"{indent}    self.consecutive_failures += 1\n"
            f"{indent}    logger.warning(\"OTLP HTTP %s: %s — %s\", exc.response.status_code, signal_name, exc.response.text[:300])\n"
            f"{indent}{m.group(2)}"
        )
    new_content, n = re.subn(pat2, broaden_except, content)
    if n:
        content = new_content
        applied.append(f"HTTPStatusError except added ({n} site(s))")

    # --- Patch 3: add a warning log inside the RequestError block if not already there
    pat3 = r'(except\s+httpx\.RequestError\s+as\s+exc\s*:\n)([ \t]+)(self\.consecutive_failures\s*\+=\s*1\n)(?!.*logger\.warning.*network)'
    def add_req_log(m):
        return (
            f"{m.group(1)}"
            f"{m.group(2)}{m.group(3)}"
            f"{m.group(2)}logger.warning(\"OTLP network error (%s): %s\", signal_name, exc)\n"
        )
    new_content, n = re.subn(pat3, add_req_log, content, flags=re.DOTALL)
    if n:
        content = new_content
        applied.append(f"RequestError warning log added ({n} site(s))")

    if applied:
        with open(path, "w") as f:
            f.write(content)
        for msg in applied:
            print(f"telemetry.py: {msg} ✓")
    else:
        print("WARN: telemetry.py — no patch patterns matched; file may already be patched or structure changed", file=sys.stderr)
        # Show a snippet around the _send method for diagnostics
        lines = content.splitlines()
        for i, line in enumerate(lines):
            if '_send' in line or 'raise_for_status' in line or 'HTTPStatusError' in line:
                print(f"  line {i+1}: {line}", file=sys.stderr)
except Exception as e:
    print(f"WARN: telemetry.py patch failed: {e}", file=sys.stderr)
TELEMETRY_PATCH_EOF

