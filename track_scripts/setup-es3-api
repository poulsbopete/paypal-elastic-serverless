_SSL_CTX = ssl.create_default_context()

def _http_post(url, auth_header, data_bytes):
    """POST data_bytes to url; returns (status_code, body_text)."""
    req = urllib.request.Request(
        url, data=data_bytes,
        headers={'Authorization': auth_header, 'Content-Type': 'application/json'},
        method='POST')
    try:
        with urllib.request.urlopen(req, context=_SSL_CTX, timeout=15) as resp:
            return resp.status, resp.read().decode('utf-8', errors='replace')
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode('utf-8', errors='replace')
    except Exception as e:
        return 0, str(e)

def send(url, auth_header, signal, payload):
    data = json.dumps(payload).encode()
    status, body = _http_post(f'{url}/v1/{signal}', auth_header, data)
    if status == 200:
        return True
    log.warning('OTLP %s HTTP %s: %s', signal, status, body[:300])
    return False

def probe_otlp_auth(url, apm_key, api_key, basic_auth):
    """Try all auth headers against the OTLP endpoint; return working header or None."""
    test_data = json.dumps(make_logs(SERVICES[:1], 1)).encode()
    candidates = []
    if apm_key:
        candidates.append(('APM-ApiKey', f'ApiKey {apm_key}'))
    if api_key:
        candidates.append(('ES-ApiKey',  f'ApiKey {api_key}'))
    if basic_auth:
        candidates.append(('Basic',       f'Basic {basic_auth}'))
    for label, header in candidates:
        status, body = _http_post(f'{url}/v1/logs', header, test_data)
        log.info('OTLP auth probe [%s]: HTTP %s', label, status)
        if status == 200:
            log.info('OTLP AUTH OK with %s ✓', label)
            return ('otlp', header)
        log.warning('  rejected: %s', body[:200])
    return None

def _bulk_write(es_url, auth_header, index, docs):
    """Write docs to an ES index/data-stream via _bulk.
    Returns (success_count, error_reason_or_None)."""
    lines = []
    for doc in docs:
        lines.append('{"create":{}}')
        lines.append(json.dumps(doc))
    body = ('\n'.join(lines) + '\n').encode()
    req = urllib.request.Request(
        f'{es_url}/{index}/_bulk', data=body,
        headers={'Authorization': auth_header, 'Content-Type': 'application/x-ndjson'},
        method='POST')
    try:
        with urllib.request.urlopen(req, context=_SSL_CTX, timeout=15) as r:
            resp = json.loads(r.read())
    except urllib.error.HTTPError as e:
        return 0, f'HTTP {e.code}: {e.read().decode("utf-8","replace")[:200]}'
    except Exception as e:
        return 0, str(e)

    if resp.get('errors'):
        errors = [i.get('create',{}).get('error',{}).get('reason','?')
                  for i in resp.get('items',[]) if i.get('create',{}).get('error')]
        if errors:
            return 0, errors[0]
    successes = sum(1 for i in resp.get('items',[])
                    if i.get('create',{}).get('status') in (200,201))
    return successes, None

def es_bulk_write(es_url, auth_header, index, docs):
    n, err = _bulk_write(es_url, auth_header, index, docs)
    if err:
        log.warning('ES bulk [%s] error: %s', index, err)
        return False
    return n > 0

def probe_es_direct(es_url, api_key):
    """Try writing a test doc directly to ES; return (auth_header, index) or None.

    Use paypal-otel-logs (plain index, dynamic mapping, no ingest pipeline) first.
    The managed logs-apm.otel-default data stream has an APM ingest pipeline that
    reroutes/drops non-OTel documents while still returning HTTP 200 per item.
    """
    if not es_url or not api_key:
        return None
    auth = f'ApiKey {api_key}'
    from datetime import datetime, timezone
    test_doc = {
        '@timestamp': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ'),
        'service.name': 'order-gateway',
        'severity_text': 'INFO',
        'body.text': 'ES-direct probe',
        'trace.id': 'probe000',
        'trade.id': 'TRD-PROBE',
    }
    # paypal-otel-logs is a plain index — dynamic mapping, no ingest pipeline.
    # logs-apm.otel-default pipeline drops non-OTel docs while returning HTTP 200.
    for index in ('paypal-otel-logs', 'paypal-logs-default'):
        n, err = _bulk_write(es_url, auth, index, [test_doc])
        log.info('ES probe [%s]: %s', index, 'OK' if n > 0 else f'FAIL – {err}')
        if n > 0:
            log.info('ES DIRECT WRITE OK ✓ — using index [%s]', index)
            return auth, index
    return None

