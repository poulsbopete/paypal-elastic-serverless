#!/usr/bin/env python3
"""PayPal OTLP telemetry generator — stdlib only, no external dependencies.
Sends realistic PayPal-shaped logs, traces, and metrics to Elastic Serverless.
Reads credentials from /tmp/paypal-otlp.json written by setup-es3-api."""

import json, time, random, logging, sys, os, hashlib, ssl
import urllib.request, urllib.error

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] paypal-otel: %(message)s',
    stream=sys.stdout)
log = logging.getLogger('paypal-otel')

CFG_PATH = '/tmp/paypal-otlp.json'

SERVICES = [
    {'name': 'merchant-api',          'region': 'us-east-1', 'cloud': 'aws'},
    {'name': 'checkout-service',      'region': 'us-east-1', 'cloud': 'aws'},
    {'name': 'payments-orchestrator', 'region': 'us-east-1', 'cloud': 'aws'},
    {'name': 'fraud-decisioning',     'region': 'us-central1', 'cloud': 'gcp'},
    {'name': 'settlement-service',    'region': 'us-central1', 'cloud': 'gcp'},
    {'name': 'merchant-support-api',  'region': 'eastus', 'cloud': 'azure'},
    {'name': 'notification-service',  'region': 'eastus', 'cloud': 'azure'},
]

LOG_MESSAGES = {
    'merchant-api':          ['Merchant profile loaded', 'API key validated', 'Rate limit check passed', 'Merchant settings updated', 'Authentication failed for merchant', 'Invalid merchant ID'],
    'checkout-service':      ['Checkout session created', 'Cart validated', 'Shipping calculated', 'Session timeout', 'Cart item not found', 'Checkout session expired'],
    'payments-orchestrator': ['Payment routed to processor', 'Authorization requested', 'Payment captured', 'Routing table miss', 'Payment declined by issuer', 'Authorization timeout'],
    'fraud-decisioning':     ['Fraud score computed', 'Risk model applied', 'Transaction approved', 'High-risk signal detected', 'Model inference timeout', 'Velocity check failed'],
    'settlement-service':    ['Settlement batch started', 'Reconciliation complete', 'Funds released', 'Batch file missing', 'Settlement deadline missed', 'Reconciliation error'],
    'merchant-support-api':  ['Support ticket created', 'Case escalated', 'Account lookup complete', 'Ticket not found', 'SLA breach detected', 'Escalation failed'],
    'notification-service':  ['Email delivered', 'Push notification sent', 'Webhook dispatched', 'Delivery failed: invalid address', 'Webhook timeout', 'Push token expired'],
}

def _rand_id(n=16):
    return hashlib.sha256(str(random.random()).encode()).hexdigest()[:n*2]

def _ts_ns():
    return int(time.time() * 1e9)

def _attrs(svc):
    return [
        {'key': 'service.name',    'value': {'stringValue': svc['name']}},
        {'key': 'cloud.provider',  'value': {'stringValue': svc['cloud']}},
        {'key': 'cloud.region',    'value': {'stringValue': svc['region']}},
        {'key': 'deployment.environment', 'value': {'stringValue': 'production'}},
    ]

def make_logs(svcs, n_per_svc=3):
    resource_logs = []
    for svc in svcs:
        msgs = LOG_MESSAGES.get(svc['name'], ['Processing request'])
        records = []
        for _ in range(n_per_svc):
            is_error = random.random() < 0.12
            msg = random.choice(msgs[3:] if is_error and len(msgs) > 3 else msgs[:3])
            records.append({
                'timeUnixNano': str(_ts_ns()),
                'severityText': 'ERROR' if is_error else random.choice(['INFO', 'INFO', 'WARN']),
                'severityNumber': 17 if is_error else 9,
                'body': {'stringValue': msg},
                'traceId': _rand_id(16),
                'spanId': _rand_id(8),
                'attributes': [
                    {'key': 'merchant.id', 'value': {'stringValue': f'M-{random.randint(10000,99999)}'}},
                    {'key': 'transaction.type', 'value': {'stringValue': random.choice(['payment','refund','dispute'])}},
                ],
            })
        resource_logs.append({
            'resource': {'attributes': _attrs(svc)},
            'scopeLogs': [{'scope': {'name': svc['name']}, 'logRecords': records}],
        })
    return {'resourceLogs': resource_logs}

def make_traces(svcs, n=2):
    resource_spans = []
    for svc in random.sample(svcs, min(n, len(svcs))):
        trace_id = _rand_id(16)
        spans = []
        for i in range(random.randint(1, 4)):
            dur = random.randint(5, 500) * 1_000_000
            start = _ts_ns() - dur
            spans.append({
                'traceId': trace_id,
                'spanId': _rand_id(8),
                'name': random.choice(['POST /api/payment', 'GET /merchant', 'process_transaction', 'fraud_check']),
                'kind': 2,
                'startTimeUnixNano': str(start),
                'endTimeUnixNano': str(start + dur),
                'status': {'code': 2 if random.random() < 0.08 else 1},
                'attributes': [
                    {'key': 'http.method', 'value': {'stringValue': 'POST'}},
                    {'key': 'http.status_code', 'value': {'intValue': random.choice([200,200,200,500,429])}},
                ],
            })
        resource_spans.append({
            'resource': {'attributes': _attrs(svc)},
            'scopeSpans': [{'scope': {'name': svc['name']}, 'spans': spans}],
        })
    return {'resourceSpans': resource_spans}

def make_metrics(svcs):
    resource_metrics = []
    for svc in svcs:
        ts = str(_ts_ns())
        metrics = [
            {'name': 'http.server.request.duration',
             'description': 'HTTP server request duration',
             'unit': 'ms',
             'gauge': {'dataPoints': [{'timeUnixNano': ts,
               'asDouble': random.uniform(5, 500),
               'attributes': [{'key': 'http.route', 'value': {'stringValue': '/api/payment'}}]}]}},
            {'name': 'payment.success.rate',
             'description': 'Payment success rate',
             'unit': '1',
             'gauge': {'dataPoints': [{'timeUnixNano': ts,
               'asDouble': random.uniform(0.94, 0.999),
               'attributes': []}]}},
        ]
        resource_metrics.append({
            'resource': {'attributes': _attrs(svc)},
            'scopeMetrics': [{'scope': {'name': svc['name']}, 'metrics': metrics}],
        })
    return {'resourceMetrics': resource_metrics}

_SSL_CTX = ssl.create_default_context()

def _http_post(url, auth_header, data_bytes):
    """POST data_bytes to url; returns (status_code, body_text)."""
    req = urllib.request.Request(
        url, data=data_bytes,
        headers={'Authorization': auth_header, 'Content-Type': 'application/json'},
        method='POST')
    try:
        with urllib.request.urlopen(req, context=_SSL_CTX, timeout=15) as resp:
            return resp.status, resp.read().decode('utf-8', errors='replace')
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode('utf-8', errors='replace')
    except Exception as e:
        return 0, str(e)

def send(url, auth_header, signal, payload):
    data = json.dumps(payload).encode()
    status, body = _http_post(f'{url}/v1/{signal}', auth_header, data)
    if status == 200:
        return True
    log.warning('OTLP %s HTTP %s: %s', signal, status, body[:300])
    return False

def probe_otlp_auth(url, apm_key, api_key, basic_auth):
    """Try all auth headers against the OTLP endpoint; return working header or None."""
    test_data = json.dumps(make_logs(SERVICES[:1], 1)).encode()
    candidates = []
    if apm_key:
        candidates.append(('APM-ApiKey', f'ApiKey {apm_key}'))
    if api_key:
        candidates.append(('ES-ApiKey',  f'ApiKey {api_key}'))
    if basic_auth:
        candidates.append(('Basic',       f'Basic {basic_auth}'))
    for label, header in candidates:
        status, body = _http_post(f'{url}/v1/logs', header, test_data)
        log.info('OTLP auth probe [%s]: HTTP %s', label, status)
        if status == 200:
            log.info('OTLP AUTH OK with %s ✓', label)
            return ('otlp', header)
        log.warning('  rejected: %s', body[:200])
    return None

def _bulk_write(es_url, auth_header, index, docs):
    """Write docs to an ES index/data-stream via _bulk.
    Returns (success_count, error_reason_or_None)."""
    lines = []
    for doc in docs:
        lines.append('{"create":{}}')
        lines.append(json.dumps(doc))
    body = ('\n'.join(lines) + '\n').encode()
    req = urllib.request.Request(
        f'{es_url}/{index}/_bulk', data=body,
        headers={'Authorization': auth_header, 'Content-Type': 'application/x-ndjson'},
        method='POST')
    try:
        with urllib.request.urlopen(req, context=_SSL_CTX, timeout=15) as r:
            resp = json.loads(r.read())
    except urllib.error.HTTPError as e:
        return 0, f'HTTP {e.code}: {e.read().decode("utf-8","replace")[:200]}'
    except Exception as e:
        return 0, str(e)

    if resp.get('errors'):
        errors = [i.get('create',{}).get('error',{}).get('reason','?')
                  for i in resp.get('items',[]) if i.get('create',{}).get('error')]
        if errors:
            return 0, errors[0]
    successes = sum(1 for i in resp.get('items',[])
                    if i.get('create',{}).get('status') in (200,201))
    return successes, None

def es_bulk_write(es_url, auth_header, index, docs):
    n, err = _bulk_write(es_url, auth_header, index, docs)
    if err:
        log.warning('ES bulk [%s] error: %s', index, err)
        return False
    return n > 0

def probe_es_direct(es_url, api_key):
    """Try writing a test doc directly to ES; return (auth_header, index) or None.

    Use paypal-otel-logs (plain index, dynamic mapping, no ingest pipeline) first.
    The managed logs-apm.otel-default data stream has an APM ingest pipeline that
    reroutes/drops non-OTel documents while still returning HTTP 200 per item.
    """
    if not es_url or not api_key:
        return None
    auth = f'ApiKey {api_key}'
    from datetime import datetime, timezone
    test_doc = {
        '@timestamp': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ'),
        'service.name': 'checkout-service',
        'severity_text': 'INFO',
        'body.text': 'ES-direct probe',
        'trace.id': 'probe000',
        'merchant.id': 'M-PROBE',
    }
    # paypal-otel-logs is a plain index — dynamic mapping, no ingest pipeline.
    # logs-apm.otel-default pipeline drops non-OTel docs while returning HTTP 200.
    for index in ('paypal-otel-logs', 'paypal-logs-default'):
        n, err = _bulk_write(es_url, auth, index, [test_doc])
        log.info('ES probe [%s]: %s', index, 'OK' if n > 0 else f'FAIL – {err}')
        if n > 0:
            log.info('ES DIRECT WRITE OK ✓ — using index [%s]', index)
            return auth, index
    return None

TRANSACTION_NAMES = {
    'checkout-service':      ['POST /api/checkout/initiate','POST /api/checkout/confirm','GET /api/checkout/status'],
    'payments-orchestrator': ['POST /api/payments/authorize','POST /api/payments/capture','POST /api/payments/void'],
    'fraud-decisioning':     ['POST /api/fraud/score','POST /api/fraud/review','GET /api/fraud/rules'],
    'merchant-api':          ['GET /api/merchant/profile','PUT /api/merchant/settings','POST /api/merchant/verify'],
    'settlement-service':    ['POST /api/settlement/batch','GET /api/settlement/status','POST /api/settlement/reconcile'],
    'merchant-support-api':  ['POST /api/support/ticket','GET /api/support/case','PUT /api/support/escalate'],
    'notification-service':  ['POST /api/notify/email','POST /api/notify/push','POST /api/notify/webhook'],
}
# P99 latency baseline per service (ms) — used to generate realistic durations
SVC_LATENCY_MS = {
    'checkout-service': 145, 'payments-orchestrator': 320, 'fraud-decisioning': 85,
    'merchant-api': 45, 'settlement-service': 210, 'merchant-support-api': 60,
    'notification-service': 30,
}

def make_es_log_docs(svcs, n_per_svc=3):
    """Generate PayPal-shaped telemetry docs for ES _bulk API.
    Each doc includes log, trace, and RED metric fields for rich ES|QL queries."""
    from datetime import datetime, timezone
    docs = []
    for svc in svcs:
        msgs = LOG_MESSAGES.get(svc['name'], ['Processing request'])
        base_ms = SVC_LATENCY_MS.get(svc['name'], 100)
        txn_names = TRANSACTION_NAMES.get(svc['name'], ['GET /api/request'])
        for _ in range(n_per_svc):
            is_error = random.random() < 0.12
            msg = random.choice(msgs[3:] if is_error and len(msgs) > 3 else msgs[:3])
            # Latency: normal distribution around baseline, spikes on errors
            duration_ms = max(5, int(random.gauss(base_ms * (4 if is_error else 1), base_ms * 0.3)))
            http_status = random.choice([500, 503, 504]) if is_error else random.choice([200, 200, 200, 201, 202])
            docs.append({
                '@timestamp': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ'),
                'service.name': svc['name'],
                'cloud.provider': svc['cloud'],
                'cloud.region': svc['region'],
                'deployment.environment': 'production',
                'severity_text': 'ERROR' if is_error else random.choice(['INFO','INFO','WARN']),
                'body.text': msg,
                'trace.id': _rand_id(32),
                'span.id': _rand_id(16),
                'transaction.id': _rand_id(16),
                'transaction.name': random.choice(txn_names),
                'transaction.duration.us': duration_ms * 1000,
                'http.response.status_code': http_status,
                'merchant.id': f'M-{random.randint(10000,99999)}',
                'merchant.tier': random.choice(['enterprise','business','standard']),
                'payment.method': random.choice(['card','paypal_balance','bank','bnpl']),
            })
    return docs

def load_cfg():
    for _ in range(30):
        try:
            with open(CFG_PATH) as f:
                cfg = json.load(f)
            if cfg.get('otlp_url') or cfg.get('es_url'):
                log.info('Config loaded')
                return cfg
        except Exception:
            pass
        time.sleep(2)
    log.error('Could not load config from %s after 60s', CFG_PATH)
    return None

def main():
    cfg = load_cfg()
    if not cfg:
        sys.exit(1)

    otlp_url   = cfg.get('otlp_url', '')
    es_url     = cfg.get('es_url', '')
    apm_key    = cfg.get('apm_key', '')
    api_key    = cfg.get('api_key', '')
    basic_auth = cfg.get('basic_auth', '')

    log.info('Starting PayPal telemetry generator')
    log.info('  OTLP endpoint: %s', otlp_url)
    log.info('  ES endpoint:   %s', es_url)

    # Strategy 1: OTLP to APM endpoint
    mode = None
    auth_header = None
    if otlp_url:
        result = probe_otlp_auth(otlp_url, apm_key, api_key, basic_auth)
        if result:
            mode, auth_header = result

    # Strategy 2: Write directly to ES data stream via _bulk
    es_index = None
    if not mode and es_url and api_key:
        result = probe_es_direct(es_url, api_key)
        if result:
            auth_header, es_index = result
            mode = 'es-direct'

    if not mode:
        log.error('No working write method found — giving up.')
        sys.exit(1)

    log.info('Using mode: %s  index: %s', mode, es_index or 'n/a')
    tick = 0
    while True:
        try:
            if mode == 'otlp':
                ok = send(otlp_url, auth_header, 'logs', make_logs(SERVICES, random.randint(2,5)))
                if ok:
                    log.info('[otlp] Sent logs for %d services (tick %d)', len(SERVICES), tick)
                if tick % 2 == 0:
                    ok = send(otlp_url, auth_header, 'traces', make_traces(SERVICES))
                    if ok: log.info('[otlp] Sent traces ✓')
                if tick % 6 == 0:
                    ok = send(otlp_url, auth_header, 'metrics', make_metrics(SERVICES))
                    if ok: log.info('[otlp] Sent metrics ✓')
            else:  # es-direct
                docs = make_es_log_docs(SERVICES, random.randint(2,5))
                ok = es_bulk_write(es_url, auth_header, es_index, docs)
                if ok:
                    log.info('[es-direct→%s] Indexed %d docs (tick %d)', es_index, len(docs), tick)
        except Exception as e:
            log.error('Generator loop error: %s', e)
        tick += 1
        time.sleep(5)

if __name__ == '__main__':
    main()
OTELGEN_EOF

