def make_es_log_docs(svcs, n_per_svc=3):
    """Generate financial-platform telemetry docs for ES _bulk API.
    Each doc includes log, trace, and RED metric fields for rich ES|QL queries."""
    from datetime import datetime, timezone
    instruments = ['AAPL', 'GOOGL', 'MSFT', 'AMZN', 'JPM', 'GS', 'FX.EURUSD', 'FUT.ES', 'FUT.NQ']
