    for i in range(1, len(thresholds)):
        color_stops.append({"color": thresholds[i][0], "stop": thresholds[i-1][1]})
    return {"name": "custom", "type": "palette", "params": {
        "steps": len(thresholds), "name": "custom", "reverse": False,
        "rangeType": "number", "rangeMin": 0, "rangeMax": None,
        "progression": "fixed", "stops": stops, "colorStops": color_stops,
        "continuity": "above", "maxSteps": 5}}

