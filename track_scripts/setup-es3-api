' > /etc/nginx/conf.d/default.conf

echo "Restart NGINX"
systemctl restart nginx

# Verify NGINX is running and listening on port 8080
sleep 2
if systemctl is-active --quiet nginx; then
    echo "✅ NGINX is running"
    if netstat -tlnp 2>/dev/null | grep -q ":8080 " || ss -tlnp 2>/dev/null | grep -q ":8080 "; then
        echo "✅ NGINX is listening on port 8080"
    else
        echo "⚠️  Warning: NGINX may not be listening on port 8080"
    fi
else
    echo "❌ ERROR: NGINX failed to start"
    systemctl status nginx || true
    exit 1
fi

echo "Setting up JSON server on port 8081..."

# Check if the JSON file exists
if [ ! -f "/tmp/project_results.json" ]; then
    echo "Warning: /tmp/project_results.json not found!"
    echo "The server will return an error when accessed."
fi

# Assume nothing is running on port 8081
echo "Starting JSON server on port 8081..."

# Start the server in background
echo "Starting JSON server in background..."
python3 bin/serve_json.py > /tmp/server-serve-json.log 2>&1 &

# Get the process ID
SERVER_PID=$!

# Wait a moment for the server to start
sleep 2

# Check if server started successfully
sleep 2
if kill -0 $SERVER_PID 2>/dev/null; then
    echo ":white_check_mark: Server started successfully!"
    echo ":bar_chart: Server PID: $SERVER_PID"
    echo ":memo: Logs: /tmp/server-serve-json.log"
    echo ":globe_with_meridians: Access URL: http://localhost:8081"
    echo ""
    echo ":clipboard: Useful commands:"
    echo "  View logs: tail -f /tmp/server-serve-json.log"
    echo "  Test server: curl http://localhost:8081"
    echo "  Stop server: kill $SERVER_PID"
    echo "  Check status: ps aux | grep serve_json"
else
    echo ":x: Failed to start server"
    echo "Check /tmp/server-serve-json.log for details:"
    if [ -f "/tmp/server-serve-json.log" ]; then
        tail -5 /tmp/server-serve-json.log
    else
        echo "No log file found"
    fi
    exit 1
fi

echo "done"

# ─────────────────────────────────────────────────────────────────────────────
# Elastic Observability Demo Platform setup
# Credentials (KIBANA_URL, ELASTICSEARCH_API_KEY) are already set above.
# The demo app runs on port 8090 (nginx owns 8080).
# ─────────────────────────────────────────────────────────────────────────────

DEMO_REPO="https://github.com/poulsbopete/elastic-launch-demo.git"
DEMO_BRANCH="feat/back-navigation-noc-chaos"
DEMO_DIR="/opt/elastic-launch-demo"
DEMO_PORT=8090

echo "Cloning elastic-launch-demo..."
if [[ -d "$DEMO_DIR" ]]; then
  git -C "$DEMO_DIR" pull --ff-only 2>/dev/null || true
else
  git clone --branch "$DEMO_BRANCH" "$DEMO_REPO" "$DEMO_DIR"
fi

# PayPal track: auto-launch Retail Banking (`banking`); hide Claro from the scenario picker.
echo "Patching scenario registry (remove Claro)..."
python3 <<'SCENARIO_PATCH_EOF'
from pathlib import Path
import re
p = Path("/opt/elastic-launch-demo/scenarios/__init__.py")
if not p.is_file():
    print("WARN: scenarios/__init__.py not found — skip Claro removal")
else:
    text = p.read_text(encoding="utf-8")
    new, n = re.subn(
        r'^[ \t]*"scenarios\.claro\.scenario",\s*\n',
        "",
        text,
        flags=re.MULTILINE,
    )
    if n:
        p.write_text(new, encoding="utf-8")
        print(f"Removed Claro scenario from registry ({n} line(s))")
    elif "claro.scenario" in text:
        print("WARN: claro present but pattern did not match — check scenarios/__init__.py")
    else:
        print("Claro already absent — OK")
SCENARIO_PATCH_EOF

echo "Installing Python dependencies..."
# Install into a dedicated target dir — avoids PEP 668 / EXTERNALLY-MANAGED entirely
PKGS_DIR="$DEMO_DIR/packages"
mkdir -p "$PKGS_DIR"
# Bootstrap pip into the target dir using get-pip.py (no system pip needed)
curl -fsSL https://bootstrap.pypa.io/get-pip.py | python3 - --target="$PKGS_DIR" --quiet 2>/dev/null || true
# Install all requirements into the same target dir
PYTHONPATH="$PKGS_DIR" python3 -m pip install \
  --target="$PKGS_DIR" --prefer-binary --quiet \
  -r "$DEMO_DIR/requirements.txt"
mkdir -p "$DEMO_DIR/data"

# Get Instruqt participant email to pre-fill the Chaos Controller operator field.
# Falls back to a stub so OPERATOR_EMAIL is always set and nothing downstream fails.
PARTICIPANT_EMAIL=""
if command -v instruqt &>/dev/null; then
  PARTICIPANT_EMAIL="$(instruqt participant get --format json 2>/dev/null \
    | python3 -c "import sys,json; p=json.load(sys.stdin); print(p.get('email',''))" \
    2>/dev/null || echo "")"
fi
if [[ -z "$PARTICIPANT_EMAIL" ]]; then
  # Fallback: try the runtime socket
  PARTICIPANT_EMAIL="$(curl -sf --unix-socket /var/run/instruqt/runtime.sock \
    http://localhost/participant 2>/dev/null \
    | python3 -c "import sys,json; p=json.load(sys.stdin); print(p.get('email',''))" \
    2>/dev/null || echo "")"
fi
if [[ -z "$PARTICIPANT_EMAIL" ]]; then
  PARTICIPANT_EMAIL="participant@instruqt.local"
  echo "Participant email not available — using stub: $PARTICIPANT_EMAIL"
else
  echo "Participant email resolved: $PARTICIPANT_EMAIL"
fi

echo "Creating systemd service for demo app (port $DEMO_PORT)..."
cat > /etc/systemd/system/elastic-demo.service <<EOF
[Unit]
Description=Elastic Observability Demo Platform
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=${DEMO_DIR}
Environment=PATH=${DEMO_DIR}/packages/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=PYTHONPATH=${DEMO_DIR}/packages
Environment=OPERATOR_EMAIL=${PARTICIPANT_EMAIL}
Environment=ACTIVE_SCENARIO=banking
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port ${DEMO_PORT}
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=elastic-demo

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable elastic-demo
systemctl start  elastic-demo

echo "Waiting for demo app to become healthy on port $DEMO_PORT..."
for i in $(seq 1 60); do
  if curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1; then
    echo "Demo app healthy after ${i}s ✓"
    break
  fi
  if [[ $i -eq 60 ]]; then
    echo "WARN: Demo app did not become healthy after 60s"
  fi
  sleep 1
done

# Credentials are already exported by the project-creation block above.
# KIBANA_URL and ELASTICSEARCH_API_KEY are set as env vars in this script.
DEMO_KIBANA_URL="${KIBANA_URL:-}"
DEMO_API_KEY="${ELASTICSEARCH_API_KEY:-}"

if [[ -n "$DEMO_KIBANA_URL" && -n "$DEMO_API_KEY" ]]; then
  echo "Launching retail banking scenario against $DEMO_KIBANA_URL ..."

  curl -sf -X POST "http://localhost:${DEMO_PORT}/api/setup/launch" \
    -H 'Content-Type: application/json' \
    -d "{\"scenario_id\":\"banking\",\"kibana_url\":\"${DEMO_KIBANA_URL}\",\"api_key\":\"${DEMO_API_KEY}\"}" \
    >/dev/null 2>&1 || echo "WARN: Launch request failed — learners can launch manually via the Demo App tab."

  echo "Waiting for deployment to register..."
  for i in $(seq 1 120); do
    RUNNING="$(curl -sf "http://localhost:${DEMO_PORT}/api/deployments" 2>/dev/null \
      | python3 -c "import sys,json; deps=json.load(sys.stdin); print(sum(1 for d in deps if d.get('running')))" 2>/dev/null || echo 0)"
    if [[ "$RUNNING" -ge 1 ]]; then
      echo "Deployment active after ${i}s ✓"
      break
    fi
    if [[ $i -eq 120 ]]; then
      echo "WARN: Deployment did not register after 240s"
    fi
    sleep 2
  done
else
  echo "WARN: Missing Kibana URL or API key — skipping auto-launch."
fi

# Convenience aliases
cat >> /root/.bashrc <<'BASH'

# Elastic Demo aliases
alias demo-logs="journalctl -u elastic-demo -f --no-pager"
alias demo-status="curl -sf http://localhost:8090/api/status | python3 -m json.tool"
alias demo-deployments="curl -sf http://localhost:8090/api/deployments | python3 -m json.tool"
alias demo-chaos="curl -sf http://localhost:8090/api/chaos/status | python3 -m json.tool"
alias demo-restart="systemctl restart elastic-demo && sleep 3 && curl -sf http://localhost:8090/health"
BASH

echo "Track setup complete."
