# ── Diagnostic: test OTLP auth + connectivity directly from the terminal ──────
cat > /usr/local/bin/demo-otlp-test <<'OTLP_TEST_EOF'
#!/bin/bash
# Run from the terminal to test OTLP ingestion end-to-end.
set -euo pipefail

DEPLOY=$(curl -sf http://localhost:8090/api/deployments 2>/dev/null || echo "[]")
KIBANA_URL=$(echo "$DEPLOY" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['kibana_url'] if d else '')" 2>/dev/null || true)

# Load credentials from agent vars if available
OTLP_URL=$(agent variable get ES_URL 2>/dev/null \
  | sed 's|\.es\.|.ingest.|; s|:[0-9]\{2,5\}$||; s|/$||')
OTLP_URL="${OTLP_URL}:443"
API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || true)

echo "=== PayPal OTLP Connectivity Test ==="
echo "OTLP endpoint : $OTLP_URL"
echo "API key prefix: ${API_KEY:0:12}..."
echo ""

if [[ -z "$OTLP_URL" || "$OTLP_URL" == ":443" ]]; then
  echo "ERROR: Could not read ES_URL from agent variables."
  echo "Check: agent variable get ES_URL"
  exit 1
fi

TS=$(date +%s%N 2>/dev/null || date +%s)000000000
PAYLOAD="{\"resourceLogs\":[{\"resource\":{\"attributes\":[{\"key\":\"service.name\",\"value\":{\"stringValue\":\"otlp-test\"}}]},\"scopeLogs\":[{\"scope\":{},\"logRecords\":[{\"timeUnixNano\":\"${TS}\",\"severityText\":\"INFO\",\"body\":{\"stringValue\":\"demo-otlp-test probe\"},\"attributes\":[]}]}]}]}"

echo "--- Sending test log to ${OTLP_URL}/v1/logs ---"
HTTP=$(curl -s -o /tmp/otlp_result.json -w "%{http_code}" \
  -X POST "${OTLP_URL}/v1/logs" \
  -H "Authorization: ApiKey ${API_KEY}" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD" 2>&1) || HTTP="000"

echo "HTTP status: $HTTP"
cat /tmp/otlp_result.json 2>/dev/null | python3 -m json.tool 2>/dev/null || cat /tmp/otlp_result.json 2>/dev/null
echo ""

if [[ "$HTTP" == "200" ]]; then
  echo "✓ OTLP auth OK — logs are being accepted. Data should appear in Kibana within 30s."
  echo ""
  echo "--- Checking Elasticsearch data streams ---"
  ES_URL=$(agent variable get ES_URL 2>/dev/null || true)
  DS=$(curl -sf "${ES_URL}/_data_stream/logs-apm.otel-*" \
    -H "Authorization: ApiKey ${API_KEY}" 2>/dev/null \
    | python3 -c "import sys,json; d=json.load(sys.stdin); [print('  '+s['name'], s.get('status','')) for s in d.get('data_streams',[])]" 2>/dev/null || echo "  (unable to query data streams)")
  echo "$DS"
elif [[ "$HTTP" == "401" || "$HTTP" == "403" ]]; then
  echo "✗ Authentication failed (HTTP $HTTP) — API key may be expired or lack write permissions."
  echo "  Try: agent variable get ES_API_KEY"
elif [[ "$HTTP" == "000" ]]; then
  echo "✗ Connection failed — check network access to OTLP endpoint."
else
  echo "✗ Unexpected HTTP $HTTP — see response above."
fi
OTLP_TEST_EOF

