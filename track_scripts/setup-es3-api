# ── SLO Management Workflow ───────────────────────────────────────────────────
# Creates an Elastic Workflow that idempotently manages SLOs for all PayPal
# services. The workflow runs every 24h (and manually), deletes any existing
# Availability/Latency/Error Rate SLOs, then creates 3 grouped SLOs that
# automatically produce per-service instances via groupBy: service.name.
# After creating the workflow, we trigger it immediately to populate SLOs.
if [[ -n "$KIBANA_URL" && -n "$BASE64" ]]; then
  echo "Creating PayPal SLO Management Workflow..."

  python3 - <<SLO_WF_EOF
import json, urllib.request, urllib.error, ssl, sys, time

KIBANA = '${KIBANA_URL}'
AUTH   = 'Basic ${BASE64}'
CTX    = ssl.create_default_context()

def kbn(method, path, body=None):
    data = json.dumps(body).encode() if body is not None else None
    req  = urllib.request.Request(
        f'{KIBANA}{path}', data=data, method=method,
        headers={'Authorization': AUTH, 'kbn-xsrf': 'true',
                 'Content-Type': 'application/json'})
    try:
        with urllib.request.urlopen(req, context=CTX, timeout=30) as r:
            return r.status, json.loads(r.read())
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode('utf-8','replace')
    except Exception as ex:
        return 0, str(ex)

# ── Workflow definition ───────────────────────────────────────────────────────
# Adapted from user-supplied template:
# - index updated to paypal-otel-logs (our actual data index)
# - filters updated to match ECS fields we generate
# - groupBy: service.name creates per-service SLO instances automatically
workflow = {
    'name': 'SLO Management and Service Evaluation Workflow',
    'enabled': True,
    'description': (
        'Automatically evaluates all 9 financial platform services and creates SLOs. '
        'Runs every 24 hours. IDEMPOTENT: Deletes all existing SLOs matching '
        'Availability/Latency/Error Rate names, then creates 3 standard grouped SLOs. '
        'groupBy: service.name produces one SLO per service: order-gateway, matching-engine, '
        'risk-calculator, market-data-feed, settlement-processor, fraud-detector, '
        'compliance-monitor, customer-portal, audit-logger. '
        'SLO Targets: Availability 95%, Error Rate 95%, Latency 85% under 2s.'
    ),
    'triggers': [
        {'type': 'scheduled', 'with': {'every': '24h'}},
        {'type': 'manual'},
    ],
    'steps': [
        {
            'name': 'workflow-start',
            'type': 'console',
            'with': {'message': (
                '================================================\n'
                'PayPal SLO Management Workflow - Starting\n'
                '================================================\n\n'
                'Execution ID: {{ execution.id }}\n'
                'Timestamp: {{ now | date: \'%Y-%m-%d %H:%M:%S UTC\' }}\n\n'
                'IDEMPOTENT: Deletes existing SLOs, then creates 3 grouped SLOs\n'
                'that auto-expand to per-service instances via groupBy: service.name\n'
                '================================================'
            )},
        },
        {
            'name': 'get-all-existing-slos',
            'type': 'kibana.request',
            'on-failure': {'continue': True},
            'with': {
                'method': 'GET',
                'path': '/api/observability/slos?perPage=500',
                'timeout': '60',
                'headers': {'Content-Type': 'application/json', 'Accept': 'application/json', 'kbn-xsrf': 'true'},
            },
        },
        {
            'name': 'loop_over_results',
            'type': 'foreach',
            'foreach': '{{steps.get-all-existing-slos.output.results}}',
            'on-failure': {'continue': True},
            'steps': [
                {
                    'name': 'check_SLOs',
                    'type': 'if',
                    'condition': 'foreach.item.name : *Error Rate SLO* OR foreach.item.name : *Latency SLO* OR foreach.item.name : *Availability SLO*',
                    'steps': [
                        {
                            'name': 'print-results',
                            'type': 'console',
                            'with': {'message': '{{foreach.item.name | uniq}}: {{foreach.item.id | uniq}}'},
                        },
                        {
                            'name': 'delete-loop-slo',
                            'type': 'kibana.request',
                            'on-failure': {'continue': True},
                            'with': {
                                'method': 'DELETE',
                                'path': '/api/observability/slos/{{ foreach.item.id | uniq}}',
                                'headers': {'kbn-xsrf': 'true'},
                            },
                        },
                    ],
                    'else': [
                        {
                            'name': 'print-else-results',
                            'type': 'console',
                            'with': {'message': '{{foreach.item.name | uniq}}: {{foreach.item.id | uniq}}'},
                        },
                    ],
                },
            ],
        },
        {
            'name': 'create-slo-availability',
            'type': 'kibana.request',
            'with': {
                'method': 'POST',
                'path': '/api/observability/slos',
                'body': {
                    'name': 'Availability SLO',
                    'description': 'PayPal service availability — 95% of requests succeed (HTTP < 500). Grouped by service.name, producing one instance per PayPal microservice.',
                    'indicator': {
                        'type': 'sli.kql.custom',
                        'params': {
                            'index': 'paypal-otel-logs',
                            'timestampField': '@timestamp',
                            'filter': 'service.name: *',
                            'good': 'http.response.status_code < 500',
                            'total': 'service.name: *',
                        },
                    },
                    'groupBy': ['service.name'],
                    'budgetingMethod': 'occurrences',
                    'timeWindow': {'duration': '7d', 'type': 'rolling'},
                    'objective': {'target': 0.95},
                    'tags': ['paypal', 'availability'],
                },
                'headers': {'Content-Type': 'application/json', 'Accept': 'application/json', 'kbn-xsrf': 'true'},
            },
        },
        {
            'name': 'create-slo-latency',
            'type': 'kibana.request',
            'with': {
                'method': 'POST',
                'path': '/api/observability/slos',
                'body': {
                    'name': 'Latency SLO',
                    'description': 'PayPal service latency — 85% of requests complete in under 2s. Grouped by service.name. CAL DURATION_MS equivalent.',
                    'indicator': {
                        'type': 'sli.kql.custom',
                        'params': {
                            'index': 'paypal-otel-logs',
                            'timestampField': '@timestamp',
                            'filter': 'transaction.duration.us: *',
                            'good': 'transaction.duration.us <= 2000000',
                            'total': 'transaction.duration.us: *',
                        },
                    },
                    'groupBy': ['service.name'],
                    'budgetingMethod': 'occurrences',
                    'timeWindow': {'duration': '7d', 'type': 'rolling'},
                    'objective': {'target': 0.85},
                    'tags': ['paypal', 'latency'],
                },
                'headers': {'Content-Type': 'application/json', 'Accept': 'application/json', 'kbn-xsrf': 'true'},
            },
        },
        {
            'name': 'create-slo-error-rate',
            'type': 'kibana.request',
            'with': {
                'method': 'POST',
                'path': '/api/observability/slos',
                'body': {
                    'name': 'Error Rate SLO',
                    'description': 'PayPal service error rate — less than 5% of requests fail. Grouped by service.name.',
                    'indicator': {
                        'type': 'sli.kql.custom',
                        'params': {
                            'index': 'paypal-otel-logs',
                            'timestampField': '@timestamp',
                            'filter': 'service.name: *',
                            'good': 'NOT severity_text: ERROR',
                            'total': 'service.name: *',
                        },
                    },
                    'groupBy': ['service.name'],
                    'budgetingMethod': 'occurrences',
                    'timeWindow': {'duration': '7d', 'type': 'rolling'},
                    'objective': {'target': 0.95},
                    'tags': ['paypal', 'error-rate'],
                },
                'headers': {'Content-Type': 'application/json', 'Accept': 'application/json', 'kbn-xsrf': 'true'},
            },
        },
    ],
}

# ── Create the workflow ───────────────────────────────────────────────────────
status, resp = kbn('POST', '/api/workflows', workflow)
if status in (200, 201):
    wf_id = resp.get('id', '') if isinstance(resp, dict) else ''
    print(f'Workflow created ✓  id={wf_id}')

    # Trigger it immediately so SLOs are created right now
    if wf_id:
        time.sleep(2)
        run_status, run_resp = kbn('POST', f'/api/workflows/{wf_id}/run', {})
        print(f'Workflow triggered: HTTP {run_status}')
elif status == 409:
    print('Workflow already exists (409) — skipping creation')
    # Try to find and trigger the existing one
    ls_status, ls_resp = kbn('GET', '/api/workflows?perPage=100')
    if isinstance(ls_resp, dict):
        for wf in ls_resp.get('results', ls_resp.get('items', [])):
            if 'SLO Management' in wf.get('name', ''):
                wf_id = wf.get('id', '')
                run_status, _ = kbn('POST', f'/api/workflows/{wf_id}/run', {})
                print(f'Existing workflow triggered: HTTP {run_status}')
                break
else:
    print(f'WARN: Workflow creation HTTP {status}: {str(resp)[:300]}')
    # Fallback: create SLOs directly via API
    print('Falling back to direct SLO creation...')
    for slo in [
        {'name': 'Availability SLO',
         'description': 'PayPal service availability — 95% of requests succeed (HTTP < 500)',
         'indicator': {'type': 'sli.kql.custom', 'params': {
             'index': 'paypal-otel-logs', 'timestampField': '@timestamp',
             'filter': 'service.name: *', 'good': 'http.response.status_code < 500', 'total': 'service.name: *'}},
         'groupBy': ['service.name'], 'budgetingMethod': 'occurrences',
         'timeWindow': {'duration': '7d', 'type': 'rolling'}, 'objective': {'target': 0.95},
         'tags': ['paypal', 'availability']},
        {'name': 'Latency SLO',
         'description': 'PayPal service latency — 85% of requests under 2s',
         'indicator': {'type': 'sli.kql.custom', 'params': {
             'index': 'paypal-otel-logs', 'timestampField': '@timestamp',
             'filter': 'transaction.duration.us: *', 'good': 'transaction.duration.us <= 2000000', 'total': 'transaction.duration.us: *'}},
         'groupBy': ['service.name'], 'budgetingMethod': 'occurrences',
         'timeWindow': {'duration': '7d', 'type': 'rolling'}, 'objective': {'target': 0.85},
         'tags': ['paypal', 'latency']},
        {'name': 'Error Rate SLO',
         'description': 'PayPal service error rate — less than 5% errors',
         'indicator': {'type': 'sli.kql.custom', 'params': {
             'index': 'paypal-otel-logs', 'timestampField': '@timestamp',
             'filter': 'service.name: *', 'good': 'NOT severity_text: ERROR', 'total': 'service.name: *'}},
         'groupBy': ['service.name'], 'budgetingMethod': 'occurrences',
         'timeWindow': {'duration': '7d', 'type': 'rolling'}, 'objective': {'target': 0.95},
         'tags': ['paypal', 'error-rate']},
    ]:
        s, r = kbn('POST', '/api/observability/slos', slo)
        print(f'  SLO "{slo["name"]}": HTTP {s}')
SLO_WF_EOF

