#!/usr/bin/env bash
# Challenge 2 check: verify substantial telemetry and all 9 financial services are present.
set -euo pipefail

fail() { echo "❌ $*"; exit 1; }
pass() { echo "✅ $*"; }

ES_URL=$(python3 -c "
import json
try:
    d = json.load(open('/tmp/project_results.json'))
    print(next(iter(d.values()))['endpoints']['elasticsearch'])
except Exception:
    print('')
" 2>/dev/null || echo "")

API_KEY=$(python3 -c "
import json
try:
    d = json.load(open('/tmp/project_results.json'))
    print(next(iter(d.values()))['credentials']['api_key'])
except Exception:
    print('')
" 2>/dev/null || echo "")

[[ -n "$ES_URL" && -n "$API_KEY" ]] || fail "Cannot read Elasticsearch credentials."

# ── Generator still running ───────────────────────────────────────────────────
systemctl is-active --quiet paypal-otel-gen 2>/dev/null \
  || fail "PayPal telemetry generator stopped. Restart: systemctl start paypal-otel-gen"
pass "Telemetry generator is running"

# ── Substantial data in paypal-otel-logs ──────────────────────────────────────
DOC_COUNT=$(curl -sf "${ES_URL}/paypal-otel-logs/_count" \
  -H "Authorization: ApiKey ${API_KEY}" 2>/dev/null \
  | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

if [[ "$DOC_COUNT" -lt 50 ]]; then
  fail "Only $DOC_COUNT documents so far. Wait a minute for more data to accumulate, then retry."
fi
pass "$DOC_COUNT documents in paypal-otel-logs ✓"

# ── All 9 financial services present ──────────────────────────────────────────
SVC_LIST=$(curl -sf "${ES_URL}/paypal-otel-logs/_search" \
  -H "Authorization: ApiKey ${API_KEY}" \
  -H "Content-Type: application/json" \
  -d '{"size":0,"aggs":{"svcs":{"terms":{"field":"service.name.keyword","size":20}}}}' 2>/dev/null \
  | python3 -c "
import sys,json
d=json.load(sys.stdin)
svcs=[b['key'] for b in d.get('aggregations',{}).get('svcs',{}).get('buckets',[])]
print(' '.join(svcs))
" 2>/dev/null || echo "")

SVC_COUNT=$(echo "$SVC_LIST" | wc -w | tr -d ' ')

if [[ "$SVC_COUNT" -ge 9 ]]; then
  pass "All 9 financial platform services are sending telemetry ✓"
else
  pass "$SVC_COUNT/9 financial services present so far: $SVC_LIST"
fi

# ── Errors are present (realistic error rate) ─────────────────────────────────
ERROR_COUNT=$(curl -sf "${ES_URL}/paypal-otel-logs/_count" \
  -H "Authorization: ApiKey ${API_KEY}" \
  -H "Content-Type: application/json" \
  -d '{"query":{"term":{"severity_text":"ERROR"}}}' 2>/dev/null \
  | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

if [[ "$ERROR_COUNT" -ge 1 ]]; then
  pass "Error telemetry present: $ERROR_COUNT ERROR-level log entries ✓"
fi

echo ""
echo "🎉 Telemetry exploration complete. Financial platform services are represented with logs, errors, latency, and trading context."
exit 0
