#!/usr/bin/env bash
# Challenge 2 solve: ensure generator is running with substantial data.
set -euo pipefail

log()  { printf "[ch2-solve] %s\n" "$*"; }

systemctl is-active --quiet paypal-otel-gen 2>/dev/null || {
  log "Restarting generator..."
  systemctl restart paypal-otel-gen || true
  sleep 8
}

ES_URL=$(python3 -c "import json; d=json.load(open('/tmp/project_results.json')); print(next(iter(d.values()))['endpoints']['elasticsearch'])" 2>/dev/null)
API_KEY=$(python3 -c "import json; d=json.load(open('/tmp/project_results.json')); print(next(iter(d.values()))['credentials']['api_key'])" 2>/dev/null)

log "Waiting for 50+ documents..."
for i in $(seq 1 30); do
  COUNT=$(curl -sf "${ES_URL}/paypal-otel-logs/_count" -H "Authorization: ApiKey ${API_KEY}" 2>/dev/null \
    | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")
  if [[ "$COUNT" -ge 50 ]]; then
    log "Data confirmed: $COUNT documents in paypal-otel-logs ✓"
    break
  fi
  sleep 2
done

log "Challenge 2 solved — telemetry exploration verified."
