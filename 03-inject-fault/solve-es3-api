#!/usr/bin/env bash
# Challenge 3 solve: programmatically trigger a fault channel.
set -euo pipefail

log()  { printf "[ch3-solve] %s\n" "$*"; }
fail() { printf "[ch3-solve ERROR] %s\n" "$*"; exit 1; }

APP="http://localhost:8090"

# ── Get deployment ID (may be empty if scenario not launched via app) ──────────
DEPS="$(curl -sf "${APP}/api/deployments" 2>/dev/null || echo "[]")"
DEP_ID="$(echo "$DEPS" | python3 -c "
import sys, json
deps = json.load(sys.stdin)
print(deps[0]['deployment_id'] if deps else '')
" 2>/dev/null || echo "")"

# ── Trigger fault (try both with and without deployment_id) ──────────────────
if [[ -n "$DEP_ID" ]]; then
  log "Triggering fault on deployment $DEP_ID..."
  curl -sf -X POST "${APP}/api/chaos/trigger" \
    -H 'Content-Type: application/json' \
    -d "{\"deployment_id\":\"${DEP_ID}\",\"channel\":1}" >/dev/null 2>&1 || true
else
  log "No deployment found — triggering global fault channel 1..."
  curl -sf -X POST "${APP}/api/chaos/trigger" \
    -H 'Content-Type: application/json' \
    -d '{"channel":1}' >/dev/null 2>&1 || true
fi

sleep 3

# ── Verify triggered ──────────────────────────────────────────────────────────
if [[ -n "$DEP_ID" ]]; then
  STATUS="$(curl -sf "${APP}/api/chaos/status?deployment_id=${DEP_ID}" 2>/dev/null || echo "{}")"
else
  STATUS="$(curl -sf "${APP}/api/chaos/status" 2>/dev/null || echo "{}")"
fi

ACTIVE="$(echo "$STATUS" | python3 -c "
import sys, json
try:
    ch = json.load(sys.stdin)
    a = [k for k,v in ch.items() if isinstance(v,dict) and v.get('state') == 'ACTIVE']
    print(len(a))
except: print(0)
" 2>/dev/null || echo "0")"

if [[ "$ACTIVE" -ge 1 ]]; then
  log "Fault channel active — errors are now flowing ✓"
else
  log "Note: chaos trigger sent (state may not reflect immediately)"
fi

log "Challenge 3 solved. Check Kibana → Observability → Alerts for the detection."
