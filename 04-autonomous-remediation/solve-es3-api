#!/usr/bin/env bash
# Challenge 4 solve: resolve all active chaos channels programmatically.
set -euo pipefail

log()  { printf "[ch4-solve] %s\n" "$*"; }
fail() { printf "[ch4-solve ERROR] %s\n" "$*"; exit 1; }

APP="http://localhost:8090"

# ── Get deployment ID ─────────────────────────────────────────────────────────
DEPS="$(curl -sf "${APP}/api/deployments" 2>/dev/null || echo "[]")"
DEP_ID="$(echo "$DEPS" | python3 -c "
import sys, json
deps = json.load(sys.stdin)
print(deps[0]['deployment_id'] if deps else '')
" 2>/dev/null || echo "")"

[[ -n "$DEP_ID" ]] || fail "No active deployment. Ensure Challenge 1 was completed."

# ── Resolve all channels ──────────────────────────────────────────────────────
log "Resolving all fault channels on deployment $DEP_ID..."

for ch in $(seq 1 20); do
  curl -sf -X POST "${APP}/api/chaos/resolve" \
    -H 'Content-Type: application/json' \
    -d "{\"deployment_id\":\"${DEP_ID}\",\"channel\":${ch}}" >/dev/null 2>&1 || true
done

sleep 2

# ── Verify all resolved ───────────────────────────────────────────────────────
CHAOS="$(curl -sf "${APP}/api/chaos/status?deployment_id=${DEP_ID}" 2>/dev/null || echo "{}")"
ACTIVE_COUNT="$(echo "$CHAOS" | python3 -c "
import sys, json
ch = json.load(sys.stdin)
print(sum(1 for v in ch.values() if isinstance(v,dict) and v.get('active')))
" 2>/dev/null || echo "0")"

if [[ "$ACTIVE_COUNT" -gt 0 ]]; then
  fail "$ACTIVE_COUNT channel(s) still active after resolve attempt."
fi

log "All fault channels resolved ✓"
log "Challenge 4 complete — the autonomous remediation loop is closed."
