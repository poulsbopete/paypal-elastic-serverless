#!/usr/bin/env bash
# Challenge 1 check: verify the financial scenario generator is running and telemetry is flowing.
set -euo pipefail

fail() { echo "❌ $*"; exit 1; }
pass() { echo "✅ $*"; }

# ── 1. Demo app is healthy ────────────────────────────────────────────────────
if ! curl -sf "http://localhost:8090/health" >/dev/null 2>&1; then
  fail "Demo app is not responding. Check: journalctl -u elastic-demo --no-pager -n 20"
fi
pass "Demo app is healthy"

# ── 2. PayPal telemetry generator is running ──────────────────────────────────
if ! systemctl is-active --quiet paypal-otel-gen 2>/dev/null; then
  fail "PayPal telemetry generator is not running. Check: journalctl -u paypal-otel-gen --no-pager -n 20"
fi
pass "PayPal telemetry generator is active"

# ── 3. Data is flowing to Elasticsearch ──────────────────────────────────────
ES_URL=$(python3 -c "
import json
try:
    d = json.load(open('/tmp/project_results.json'))
    print(next(iter(d.values()))['endpoints']['elasticsearch'])
except Exception:
    print('')
" 2>/dev/null || echo "")

API_KEY=$(python3 -c "
import json
try:
    d = json.load(open('/tmp/project_results.json'))
    print(next(iter(d.values()))['credentials']['api_key'])
except Exception:
    print('')
" 2>/dev/null || echo "")

if [[ -z "$ES_URL" || -z "$API_KEY" ]]; then
  fail "Cannot read Elasticsearch credentials from /tmp/project_results.json"
fi

DOC_COUNT=$(curl -sf "${ES_URL}/paypal-otel-logs/_count" \
  -H "Authorization: ApiKey ${API_KEY}" 2>/dev/null \
  | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

if [[ "$DOC_COUNT" -lt 10 ]]; then
  fail "Only $DOC_COUNT documents in paypal-otel-logs — telemetry is not yet flowing. Wait 30 seconds and try again. Check: journalctl -u paypal-otel-gen --no-pager -n 10"
fi
pass "Telemetry is flowing: $DOC_COUNT documents in paypal-otel-logs ✓"

# ── 4. All 9 financial services are represented ───────────────────────────────
SVC_COUNT=$(curl -sf "${ES_URL}/paypal-otel-logs/_search" \
  -H "Authorization: ApiKey ${API_KEY}" \
  -H "Content-Type: application/json" \
  -d '{"size":0,"aggs":{"svcs":{"terms":{"field":"service.name.keyword","size":20}}}}' 2>/dev/null \
  | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('aggregations',{}).get('svcs',{}).get('buckets',[])))" 2>/dev/null || echo "0")

if [[ "$SVC_COUNT" -lt 9 ]]; then
  pass "Partial: $SVC_COUNT/9 financial services seen so far (more data is flowing in)"
else
  pass "All 9 financial platform services are sending telemetry ✓"
fi

echo ""
echo "🎉 Telemetry is flowing! Open the Elastic Serverless tab and run ES|QL queries to explore the financial platform data."
exit 0
