#!/usr/bin/env bash
# Challenge 1 solve: ensure generator is running and data is in Elasticsearch.
set -euo pipefail

log()  { printf "[ch1-solve] %s\n" "$*"; }
fail() { printf "[ch1-solve ERROR] %s\n" "$*"; exit 1; }

# ── Ensure generator is running ───────────────────────────────────────────────
if ! systemctl is-active --quiet paypal-otel-gen 2>/dev/null; then
  log "Generator not running — starting it..."
  systemctl start paypal-otel-gen || true
  sleep 5
fi

if systemctl is-active --quiet paypal-otel-gen; then
  log "PayPal telemetry generator is running ✓"
else
  fail "Could not start paypal-otel-gen. Check: journalctl -u paypal-otel-gen --no-pager -n 20"
fi

# ── Wait for data to appear ───────────────────────────────────────────────────
ES_URL=$(python3 -c "
import json
d = json.load(open('/tmp/project_results.json'))
print(next(iter(d.values()))['endpoints']['elasticsearch'])
" 2>/dev/null) || fail "Cannot read ES URL from /tmp/project_results.json"

API_KEY=$(python3 -c "
import json
d = json.load(open('/tmp/project_results.json'))
print(next(iter(d.values()))['credentials']['api_key'])
" 2>/dev/null) || fail "Cannot read API key from /tmp/project_results.json"

log "Waiting for telemetry to flow into paypal-otel-logs..."
for i in $(seq 1 30); do
  DOC_COUNT=$(curl -sf "${ES_URL}/paypal-otel-logs/_count" \
    -H "Authorization: ApiKey ${API_KEY}" 2>/dev/null \
    | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

  if [[ "$DOC_COUNT" -ge 10 ]]; then
    log "Data flowing: $DOC_COUNT documents in paypal-otel-logs ✓"
    break
  fi

  if [[ $i -eq 30 ]]; then
    fail "No data in paypal-otel-logs after 60s. Check: journalctl -u paypal-otel-gen --no-pager -n 20"
  fi
  sleep 2
done

log "Challenge 1 solved — PayPal telemetry is flowing into Elastic Serverless."
