#!/usr/bin/env bash
# Challenge 1 solve: programmatically launch the fanatics scenario.
# Requires Instruqt track variables:
#   ELASTIC_KIBANA_URL  — e.g. https://my-project.kb.us-east-1.aws.elastic.cloud
#   ELASTIC_API_KEY     — just the key value (without "ApiKey " prefix)
set -euo pipefail

log()  { printf "[ch1-solve] %s\n" "$*"; }
fail() { printf "[ch1-solve ERROR] %s\n" "$*"; exit 1; }

APP="http://localhost:8090"

# ── Validate required variables ───────────────────────────────────────────────
KIBANA_URL="${ELASTIC_KIBANA_URL:-}"
API_KEY="${ELASTIC_API_KEY:-}"

[[ -n "$KIBANA_URL" ]] || fail "ELASTIC_KIBANA_URL not set. Set this as an Instruqt track variable/secret."
[[ -n "$API_KEY"    ]] || fail "ELASTIC_API_KEY not set. Set this as an Instruqt track variable/secret."

KIBANA_URL="${KIBANA_URL%/}"  # strip trailing slash

log "Testing connection to Elastic Cloud..."
CONN_RESULT="$(curl -sf -X POST "${APP}/api/setup/test-connection" \
  -H 'Content-Type: application/json' \
  -d "{\"kibana_url\":\"${KIBANA_URL}\",\"api_key\":\"${API_KEY}\"}" 2>/dev/null || echo '{}')"

CONN_OK="$(echo "$CONN_RESULT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(str(d.get('ok',False)).lower())" 2>/dev/null || echo "false")"

if [[ "$CONN_OK" != "true" ]]; then
  CONN_ERR="$(echo "$CONN_RESULT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('error','unknown'))" 2>/dev/null || echo "unknown")"
  fail "Connection test failed: $CONN_ERR. Check ELASTIC_KIBANA_URL and ELASTIC_API_KEY."
fi
log "Connection OK ✓"

log "Launching fanatics scenario..."
LAUNCH_RESULT="$(curl -sf -X POST "${APP}/api/setup/launch" \
  -H 'Content-Type: application/json' \
  -d "{\"scenario_id\":\"fanatics\",\"kibana_url\":\"${KIBANA_URL}\",\"api_key\":\"${API_KEY}\"}" 2>/dev/null || echo '{}')"

log "Launch initiated. Waiting for deployment to register..."

# Poll until a running deployment appears (deployer runs in a background thread)
for i in $(seq 1 90); do
  DEPS="$(curl -sf "${APP}/api/deployments" 2>/dev/null || echo "[]")"
  RUNNING="$(echo "$DEPS" | python3 -c "
import sys, json
deps = json.load(sys.stdin)
print(sum(1 for d in deps if d.get('running')))
" 2>/dev/null || echo "0")"

  if [[ "$RUNNING" -ge 1 ]]; then
    log "Deployment active after ${i}s ✓"
    break
  fi

  if [[ $i -eq 90 ]]; then
    fail "Deployment did not become active after 90s. Check: journalctl -u elastic-demo"
  fi
  sleep 2
done

log "Solve complete — fanatics scenario deployed and running."
